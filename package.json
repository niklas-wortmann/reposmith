{
  "name": "repoatlas",
  "version": "0.1.0",
  "description": "Make your codebase agent-ready. One command.",
  "type": "module",
  "bin": {
    "repoatlas": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "ai",
    "agents",
    "coding-agents",
    "harness-engineering",
    "developer-tools",
    "codebase-analysis",
    "documentation",
    "cli"
  ],
  "author": "Jan-Niklas Wortmann",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/niklas-wortmann/repoatlas.git"
  },
  "bugs": {
    "url": "https://github.com/niklas-wortmann/repoatlas/issues"
  },
  "homepage": "https://github.com/niklas-wortmann/repoatlas#readme",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "grammars"
  ],
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "fast-glob": "^3.3.0",
    "fast-xml-parser": "^4.4.0",
    "ignore": "^5.3.0",
    "js-yaml": "^4.1.0",
    "ora": "^8.0.0",
    "smol-toml": "^1.2.0",
    "web-tree-sitter": "^0.24.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
